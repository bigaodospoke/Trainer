{
  "name": "Trainerly",
  "version": "0.1.0",
  "private": true,
  "description": "Trainerly — plataforma competitiva de team building, analise e meta para batalhas Pokemon.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed/formats.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "sync:pokeapi": "tsx scripts/sync/pokeapi.ts",
    "sync:showdown": "tsx scripts/sync/showdown.ts",
    "sync:smogon": "tsx scripts/sync/smogon.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.2",
    "@pkmn/data": "0.10.11",
    "@pkmn/dex": "^0.10.11",
    "@pkmn/img": "^0.3.4",
    "@pkmn/sets": "5.2.0",
    "@prisma/client": "5.22.0",
    "@smogon/calc": "0.11.0",
    "clsx": "2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "11.15.0",
    "html-to-image": "^1.11.13",
    "ioredis": "5.4.1",
    "lucide-react": "0.468.0",
    "next": "15.5.19",
    "next-auth": "5.0.0-beta.31",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "2.6.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.20.1",
    "@types/react": "19.0.4",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.19",
    "postcss": "8.4.49",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
